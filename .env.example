EDAMAM_RECIPE_SEARCH_API_KEY=your-edamam-recipe-key
USDA_GOV_API_KEY=your-usda-fdc-key
SPOONACULAR_API_KEY=your-spoonacular-key

# Optional
SNAPDISH_MODEL=gpt-4o-mini
SNAPDISH_LOG_LEVEL=INFO
